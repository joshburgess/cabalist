{
  "name": "cabalist",
  "displayName": "Cabalist - Haskell .cabal Support",
  "description": "Language support for Haskell .cabal files powered by cabalist — syntax highlighting, completions, diagnostics, and quick fixes",
  "version": "0.1.0",
  "publisher": "cabalist",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshburgess/cabalist"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "haskell",
    "cabal",
    "cabal-file",
    "pvp",
    "ghc"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onLanguage:cabal",
    "workspaceContains:**/*.cabal"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cabal",
        "aliases": [
          "Cabal",
          "cabal"
        ],
        "extensions": [
          ".cabal"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "cabal-project",
        "aliases": [
          "Cabal Project"
        ],
        "filenames": [
          "cabal.project",
          "cabal.project.local",
          "cabal.project.freeze"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cabal",
        "scopeName": "source.cabal",
        "path": "./syntaxes/cabal.tmLanguage.json"
      },
      {
        "language": "cabal-project",
        "scopeName": "source.cabal",
        "path": "./syntaxes/cabal.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cabal",
        "path": "./snippets/cabal.json"
      }
    ],
    "commands": [
      {
        "command": "cabalist.restartServer",
        "title": "Cabalist: Restart Language Server"
      },
      {
        "command": "cabalist.showOutput",
        "title": "Cabalist: Show Output Channel"
      }
    ],
    "configuration": {
      "title": "Cabalist",
      "properties": {
        "cabalist.serverPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `cabalist-lsp` binary. If empty, searches `PATH`."
        },
        "cabalist.serverArgs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "markdownDescription": "Additional arguments passed to `cabalist-lsp`."
        },
        "cabalist.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the cabalist language server."
        },
        "cabalist.enableLsp": {
          "type": "boolean",
          "default": true,
          "description": "Enable the cabalist language server for diagnostics, completions, and hover."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run compile"
  }
}
